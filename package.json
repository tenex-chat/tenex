{
  "name": "@tenex-chat/backend",
  "version": "0.9.14",
  "description": "TENEX Command Line Interface",
  "bin": {
    "tenex-backend": "./dist/daemon-wrapper.cjs"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.cjs",
    "!dist/**/*.map",
    "!dist/**/__tests__",
    "!dist/**/*.test.js",
    "!dist/**/*.spec.js",
    "!dist/test-utils",
    "src/**/*.ts",
    "!src/**/__tests__",
    "!src/**/*.test.ts",
    "!src/**/*.spec.ts",
    "!src/test-utils",
    "tsconfig.json"
  ],
  "scripts": {
    "start": "bun run ./src/index.ts",
    "daemon": "bun --smol run ./src/index.ts daemon",
    "build": "bun scripts/build-bundled.js",
    "prepublishOnly": "bun run build",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "test:unit": "bun test src/**/__tests__/*.test.ts",
    "test:integration": "bun test src/**/__tests__/*.integration.test.ts",
    "audit:identity-runtime": "bun run scripts/identity-runtime-audit.ts --strict",
    "audit:transport-runtime": "bun run scripts/transport-runtime-audit.ts --strict",
    "validate:events": "bun run src/scripts/validate-events.ts",
    "typecheck": "./scripts/typecheck.sh",
    "typecheck:verbose": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "lint:architecture": "bun run scripts/lint-architecture.ts",
    "clean": "rm -rf dist node_modules bun.lockb coverage",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.68",
    "@ai-sdk/devtools": "^0.0.15",
    "@ai-sdk/openai": "^3.0.52",
    "@huggingface/transformers": "^3.8.1",
    "@inquirer/ansi": "^2.0.5",
    "@inquirer/core": "^11.1.8",
    "@lancedb/lancedb": "^0.27.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@nostr-dev-kit/ndk": "3.0.3",
    "@openrouter/ai-sdk-provider": "^2.5.1",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.71.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.213.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.213.0",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-node": "^0.213.0",
    "@opentelemetry/sdk-trace-node": "^2.6.1",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@qdrant/js-client-rest": "^1.17.0",
    "ai": "^6.0.155",
    "ai-sdk-context-management": "^0.13.1",
    "ai-sdk-fs-tools": "0.5.0",
    "ai-sdk-message-sanitizer": "0.1.3",
    "ai-sdk-provider-claude-code": "^3.4.4",
    "ai-sdk-provider-codex-cli": "1.1.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "cron-parser": "^5.5.0",
    "duck-duck-scrape": "^2.2.7",
    "inquirer": "^13.4.1",
    "lmdb": "^3.5.3",
    "lodash": "^4.18.1",
    "node-cron": "^4.2.1",
    "node-html-markdown": "^2.0.0",
    "nostr-tools": "^2.23.3",
    "ollama-ai-provider-v2": "^3.5.0",
    "sqlite-vec": "^0.1.9",
    "tseep": "^1.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "esbuild": "^0.28.0",
    "esbuild-plugin-alias": "^0.2.1",
    "eslint": "^10.2.0",
    "husky": "^9.1.7",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.4"
  },
  "type": "module",
  "keywords": [],
  "author": "",
  "license": "ISC"
}
